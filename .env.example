# =============================================================================
# MeetingAutoDocs 환경변수 예시
# =============================================================================
# 이 파일을 복사해 `.env.local` 을 만들어 실제 키를 채우세요.
#   cp .env.example .env.local
#
# 역할 요약:
#   - ZAI_API_KEY      : LLM(문서생성 GLM). 현행 메인.
#   - OPENAI_API_KEY   : Whisper STT(음성→텍스트) fallback.
#   - GEMINI_API_KEY   : STT/화자분리용 Gemini 오디오 (활성화됨).
#   - LLM_PROVIDER     : LLM을 ZAI로 강제. ⚠️ 아래 치명적 함정 필독.
# =============================================================================


# -----------------------------------------------------------------------------
# ⚠️ 치명적 — 반드시 LLM_PROVIDER=ZAI 로 명시
# -----------------------------------------------------------------------------
# GEMINI_API_KEY(STT/화자용)를 깔면, resolveProvider가 LLM provider 후보로
# Gemini까지 push합니다. 기본 우선순위가 ANTHROPIC > GEMINI > OPENAI > ZAI 이므로,
# LLM_PROVIDER를 안 정하면 LLM이 Gemini로 빼앗깁니다.
#
# 그 결과 prdChunkGenerator 의 분기(id === 'zai' ? 16384 : 8192)가 false 가 되어
# PRD 섹션 생성이 8192 토큰으로 절반 잘립니다 — 품질 사고.
#
# STT용으로 GEMINI_API_KEY를 쓰더라도, LLM은 ZAI(GLM)로 쓰려면 반드시 한 줄:
LLM_PROVIDER=ZAI


# -----------------------------------------------------------------------------
# LLM (문서 생성) — Z.ai GLM
# -----------------------------------------------------------------------------
# 코딩 플랜 구독 권장(잔액 기반이 아닌 구독 기반 무제한).
# 발급: https://z.ai/chat
ZAI_API_KEY=your-zai-api-key-here
ZAI_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
# ZAI_MODEL=glm-5-turbo


# -----------------------------------------------------------------------------
# STT fallback — OpenAI Whisper
# -----------------------------------------------------------------------------
# Gemini 오디오를 쓰지 않는 환경에서의 음성→텍스트 변환.
# 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here


# -----------------------------------------------------------------------------
# STT / 화자분리 — Gemini 오디오  (활성화됨 — 도이 작업 머징 완료)
# -----------------------------------------------------------------------------
# Gemini 2.5 Flash 네이티브 오디오 API. STT + 화자분리 동시 수행.
# 발급: https://aistudio.google.com/apikey
# 이 키가 설정되면 LLM provider 후보에도 Gemini가 추가됩니다.
# → 반드시 위의 LLM_PROVIDER=ZAI 로 LLM을 고정해야 PRD 절단 사고를 막습니다.
GEMINI_API_KEY=your-gemini-api-key-here
# STT용 모델(기본 gemini-2.5-flash). LLM용 GEMINI_MODEL과 분리.
# GEMINI_STT_MODEL=gemini-2.5-flash

# STT provider 선택 노브 (기본 whisper):
#   whisper       — OPENAI_API_KEY 의 Whisper 사용
#   gemini-audio  — GEMINI_API_KEY 의 Gemini 오디오 사용(STT+화자분리 동시)
STT_PROVIDER=whisper
